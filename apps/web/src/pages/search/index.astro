---
import Base from '@/layouts/Base.astro';
const q = Astro.url.searchParams.get('q') ?? '';
---
<Base title={q ? `Search: ${q}` : 'Search'}>
  <h1>Search</h1>
  <form method="get" action="/search">
    <input type="search" name="q" value={q} placeholder="Enter keywords..." autofocus />
    <button type="submit">Search</button>
  </form>
  <div id="results">
    {q && <p>Searching for <strong>{q}</strong> ...</p>}
  </div>
  <script define:vars={{ q }}>
    if (q) {
      fetch(`/api/search?q=${encodeURIComponent(q)}`)
        .then((r) => r.json())
        .then((data) => {
          const el = document.getElementById('results');
          if (!data.results?.length) { el.innerHTML = '<p>No results</p>'; return; }
          el.innerHTML = '<ul>' + data.results.map(
            (r) => `<li><a href="/articles/${r.slug}">${r.title}</a><p>${r.excerpt ?? ''}</p></li>`
          ).join('') + '</ul>';
        });
    }
  </script>
</Base>

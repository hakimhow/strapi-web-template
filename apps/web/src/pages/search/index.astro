---
import Base from '@/layouts/Base.astro';
// SSG 模式：搜索完全在客户端执行，走 /api/articles（nginx 反代到 Strapi v5）
---
<Base title="搜索">
  <h1>搜索</h1>
  <form id="search-form" onsubmit="return false;">
    <input type="search" id="q" placeholder="输入关键词..." autofocus />
    <button type="submit">搜索</button>
  </form>
  <div id="results"></div>

  <script is:inline>
    const form = document.getElementById('search-form');
    const input = document.getElementById('q');
    const out = document.getElementById('results');

    // URL 参数回填
    const initial = new URLSearchParams(location.search).get('q') || '';
    if (initial) { input.value = initial; runSearch(initial); }

    form.addEventListener('submit', () => {
      const q = input.value.trim();
      const u = new URL(location.href);
      if (q) u.searchParams.set('q', q); else u.searchParams.delete('q');
      history.replaceState(null, '', u);
      runSearch(q);
    });

    async function runSearch(q) {
      if (!q) { out.innerHTML = ''; return; }
      out.innerHTML = '<p>搜索中...</p>';
      const params = new URLSearchParams();
      params.set('filters[$or][0][title][$containsi]', q);
      params.set('filters[$or][1][excerpt][$containsi]', q);
      params.set('pagination[pageSize]', '20');
      params.set('sort', 'publishedAt:desc');
      params.set('status', 'published'); // v5：替代 publicationState
      try {
        const res = await fetch('/api/articles?' + params.toString());
        if (!res.ok) throw new Error(res.status);
        const data = await res.json();
        if (!data.data?.length) { out.innerHTML = '<p>无结果</p>'; return; }
        // v5 扁平响应：直接读 d.title / d.slug，不再有 d.attributes
        out.innerHTML = '<ul>' + data.data.map((d) => {
          return `<li><a href="/articles/${d.slug}/"><strong>${d.title}</strong></a>
                    ${d.excerpt ? `<p>${d.excerpt}</p>` : ''}</li>`;
        }).join('') + '</ul>';
      } catch (e) {
        out.innerHTML = '<p>搜索失败: ' + e.message + '</p>';
      }
    }
  </script>
</Base>

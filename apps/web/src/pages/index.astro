---
import Base from '@/layouts/Base.astro';
import { strapiGet, type StrapiList } from '@/lib/strapi';

interface Article { title: string; slug: string; excerpt?: string; }

let articles: StrapiList<Article>['data'] = [];
try {
  const res = await strapiGet<StrapiList<Article>>('/articles', {
    sort: 'publishedAt:desc',
    pagination: { pageSize: 10 },
  });
  articles = res.data;
} catch (e) {
  console.warn('Strapi not ready:', e);
}
---
<Base title="Home">
  <h1>Latest articles</h1>
  <ul>
    {articles.map((a) => (
      <li><a href={`/articles/${a.slug}`}>{a.title}</a></li>
    ))}
  </ul>
  {articles.length === 0 && <p>No content yet — head over to the <a href={import.meta.env.PUBLIC_STRAPI_URL + '/admin'}>Strapi admin</a> to create some.</p>}
</Base>

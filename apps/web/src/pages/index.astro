---
import Base from '@/layouts/Base.astro';
import { strapiGet, type StrapiList } from '@/lib/strapi';

interface Article { title: string; slug: string; excerpt?: string; }

// SSG：build 时拉最新 N 篇（v5 扁平响应）
let articles: StrapiList<Article>['data'] = [];
try {
  const res = await strapiGet<StrapiList<Article>>('/articles', {
    sort: 'publishedAt:desc',
    pagination: { pageSize: 10 },
    status: 'published',
  });
  articles = res.data;
} catch (e) {
  console.warn('build-time fetch failed:', e);
}
---
<Base title="首页">
  <h1>最新文章</h1>
  <ul>
    {articles.map((a) => (
      <li><a href={`/articles/${a.slug}/`}>{a.title}</a></li>
    ))}
  </ul>
  {articles.length === 0 && <p>构建时未获取到内容 —— 请检查 Strapi 是否可达，并确认已发布文章。</p>}
</Base>

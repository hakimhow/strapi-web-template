---
import Base from '@/layouts/Base.astro';
import { strapiGet } from '@/lib/strapi';

interface StrapiList<T> { data: Array<{ id: number; attributes: T }>; }
interface Article { title: string; slug: string; excerpt?: string; content?: string; }

// SSG：构建时枚举全部文章
export async function getStaticPaths() {
  try {
    const res = await strapiGet<StrapiList<Article>>('/articles', {
      pagination: { pageSize: 1000 },
    });
    return res.data.map((d) => ({
      params: { slug: d.attributes.slug },
      props: { article: d.attributes },
    }));
  } catch (e) {
    console.warn('getStaticPaths: Strapi unreachable, no articles pre-rendered', e);
    return [];
  }
}

const { article } = Astro.props as { article: Article };
---
<Base title={article.title} description={article.excerpt}>
  <article>
    <h1>{article.title}</h1>
    {article.content && <div set:html={article.content} />}
  </article>
</Base>

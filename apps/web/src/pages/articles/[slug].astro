---
import Base from '@/layouts/Base.astro';
import { strapiGet, type StrapiList } from '@/lib/strapi';

export const prerender = false;

const { slug } = Astro.params;
interface Article { title: string; slug: string; excerpt?: string; content?: string; }

const res = await strapiGet<StrapiList<Article>>('/articles', {
  filters: { slug: { $eq: slug } },
  pagination: { pageSize: 1 },
});
const article = res.data[0];
if (!article) return new Response('Not found', { status: 404 });
---
<Base title={article.title} description={article.excerpt}>
  <article>
    <h1>{article.title}</h1>
    {article.content && <div set:html={article.content} />}
  </article>
</Base>

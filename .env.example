# ============================================
# 站点身份
# ============================================
SITE_SLUG=example-site
SITE_DOMAIN=example.com
SITE_ENV=local   # local | staging | production

# ============================================
# 前端 (Astro)
# ============================================
WEB_PORT=3000
PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_STRAPI_URL=http://localhost:1337
PUBLIC_IMAGOR_URL=http://localhost:8000
# 容器内互访（compose 里使用服务名）
INTERNAL_STRAPI_URL=http://cms:1337
INTERNAL_IMAGOR_URL=http://imagor:8000

# ============================================
# Strapi
# ============================================
CMS_PORT=1337
STRAPI_APP_KEYS=changeme-key1,changeme-key2
STRAPI_API_TOKEN_SALT=changeme
STRAPI_ADMIN_JWT_SECRET=changeme
STRAPI_JWT_SECRET=changeme
STRAPI_TRANSFER_TOKEN_SALT=changeme
# Strapi 面向外部前端的 read-only token（init 时生成占位，首次登录后在 admin 面板生成真实值填入）
STRAPI_PUBLIC_TOKEN=

# ============================================
# PostgreSQL
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=strapi
DB_USER=strapi
DB_PASSWORD=changeme
DB_SSL=false

# ============================================
# Imagor
# ============================================
IMAGOR_PORT=8000
IMAGOR_SECRET=changeme
IMAGOR_UNSAFE=1   # 开发开启，生产务必改为 0 并使用签名 URL

# ============================================
# Cloudflare
# ============================================
CF_API_TOKEN=
CF_ZONE_ID=
# proxied=true 走 CDN，false 仅 DNS。init-site.sh 按 SITE_ENV 自动决定。
CF_PROXIED=false

# ============================================
# 部署 —— 远程服务器
# ============================================
DEPLOY_HOST=                 # e.g. 1.2.3.4 or deploy.example.com
DEPLOY_USER=deploy
DEPLOY_SSH_KEY=~/.ssh/id_ed25519_example
DEPLOY_PATH=/srv/example-site

# 本地服务器（staging）
STAGING_HOST=192.168.1.50
STAGING_USER=deploy
STAGING_SSH_KEY=~/.ssh/id_ed25519_lan
STAGING_PATH=/srv/example-site

# ============================================
# GHCR
# ============================================
GHCR_USER=your-github-username
GHCR_IMAGE_WEB=ghcr.io/your-github-username/example-site-web
GHCR_IMAGE_CMS=ghcr.io/your-github-username/example-site-cms

# ============================================
# 证书（仅 prod）
# ============================================
ACME_EMAIL=admin@example.com
